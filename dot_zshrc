# Pre-zshrc (device-specific)
[[ -f ~/.config/zsh/pre.local.zsh ]] && source ~/.config/zsh/pre.local.zsh

export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

# OhMyZsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="dst"
plugins=(git macos sublime zsh-autosuggestions web-search copyfile copybuffer dirhistory zsh-syntax-highlighting 1password aliases colored-man-pages command-not-found common-aliases colorize thefuck command-time)
source $ZSH/oh-my-zsh.sh

# Aliases
source ~/.zsh_aliases

ZSH_COMMAND_TIME_MIN_SECONDS=1

export EDITOR="lite-xl"

# Post-zshrc (device-specific)
[[ -f ~/.config/zsh/post.local.zsh ]] && source ~/.config/zsh/post.local.zsh
